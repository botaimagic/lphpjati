# Admin login credentials for /admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Random long string used to sign the admin session cookie.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# --- GitHub commit settings (production / Vercel) ---
# Personal access token with "repo" scope (classic) or
# fine-grained token with Contents: Read & Write on this repo.
GITHUB_TOKEN=
# "your-username/your-repo"
GITHUB_REPO=
GITHUB_BRANCH=main

# When GITHUB_TOKEN is not set (e.g. local development), the admin
# panel writes directly to content/content.json on disk instead.
